<?xml version="1.0" encoding="utf-8"?>
<!-- Selector de color para íconos del drawer. Cyan brillante cuando está activo, gris cuando no. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="#FF00E5FF" android:state_checked="true" />
    <item android:color="#FF00E5FF" android:state_activated="true" />
    <item android:color="#FF00E5FF" android:state_selected="true" />
    <item android:color="#FF6E7681" />
</selector>

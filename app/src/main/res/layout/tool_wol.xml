<?xml version="1.0" encoding="utf-8"?>
<!-- Layout para la herramienta Wake-on-LAN -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/wol_title"
            android:textColor="#FF00E5FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enciende remotamente PCs y NAS en tu red local"
            android:textColor="#FF8B949E"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- MAC input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dirección MAC"
            android:textColor="#FF6E7681"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/editMac"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/wol_mac_hint"
            android:textColor="#FFE6EDF3"
            android:textColorHint="#FF6E7681"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:background="@drawable/card_bg_about"
            android:padding="14dp"
            android:maxLength="17"
            android:singleLine="true"
            android:layout_marginBottom="12dp" />

        <!-- Broadcast IP -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Broadcast IP"
            android:textColor="#FF6E7681"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/editBroadcastIp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wol_broadcast_hint"
            android:textColor="#FFE6EDF3"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="@drawable/card_bg_about"
            android:padding="14dp"
            android:singleLine="true"
            android:layout_marginBottom="16dp" />

        <!-- Send button -->
        <TextView
            android:id="@+id/btnSendWol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wol_send"
            android:textColor="#FF0D1117"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:padding="14dp"
            android:background="@drawable/badge_online"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="8dp" />

        <!-- Result text -->
        <TextView
            android:id="@+id/txtWolResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF3FB950"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FF30363D"
            android:layout_marginBottom="20dp" />

        <!-- Known devices list -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wol_devices_title"
            android:textColor="#FF8B949E"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/wolDeviceList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/txtWolNoMacs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ejecuta un escaneo para detectar MACs"
            android:textColor="#FF6E7681"
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>

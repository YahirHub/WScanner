<?xml version="1.0" encoding="utf-8"?>
<!-- Layout para la herramienta Speed Test (LibreSpeed nativo) -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/speedtest_title"
            android:textColor="#FF00E5FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mide la velocidad de tu conexión"
            android:textColor="#FF8B949E"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descarga archivos de prueba desde CDNs públicas para medir la velocidad real de tu conexión."
            android:textColor="#FF8B949E"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- Start button -->
        <TextView
            android:id="@+id/btnStartSpeedtest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/speedtest_start"
            android:textColor="#FF0D1117"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:padding="14dp"
            android:background="@drawable/badge_online"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/speedtestProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:visibility="gone"
            android:progressTint="#FF00E5FF"
            android:progressBackgroundTint="#FF21262D"
            android:layout_marginBottom="4dp" />

        <!-- Phase text -->
        <TextView
            android:id="@+id/txtSpeedtestPhase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF8B949E"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- Results container -->
        <LinearLayout
            android:id="@+id/speedtestResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:gravity="center_horizontal">

            <!-- Velocímetro circular estilo Ookla -->
            <com.thowilabs.wscanner.SpeedometerGauge
                android:id="@+id/gaugeDownload"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_marginBottom="24dp" />

            <!-- Upload: oculto — requiere servidor que acepte POST -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/card_bg_about"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/speedtest_upload"
                    android:textColor="#FF8B949E"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtUploadSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFD29922"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Mbps"
                    android:textColor="#FF6E7681"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Ping -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/card_bg_about"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/speedtest_ping"
                    android:textColor="#FF8B949E"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtPingResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FF3FB950"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ms"
                    android:textColor="#FF6E7681"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Jitter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/card_bg_about"
                android:padding="14dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/speedtest_jitter"
                    android:textColor="#FF8B949E"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtJitterResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FF8B949E"
                    android:textSize="16sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ms"
                    android:textColor="#FF6E7681"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Share button -->
            <TextView
                android:id="@+id/btnShareSpeedtest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/speedtest_share"
                android:textColor="#FF00E5FF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:padding="12dp"
                android:background="@drawable/drawer_item_bg"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>

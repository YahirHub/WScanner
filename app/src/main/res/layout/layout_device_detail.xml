<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutDeviceDetail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Back button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/detailBtnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←  Volver"
                android:textColor="#FF00E5FF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Device icon (large) -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/circle_radar_bg" />

            <ImageView
                android:id="@+id/detailIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:alpha="0.6" />
        </FrameLayout>

        <!-- Device name -->
        <TextView
            android:id="@+id/detailName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFE6EDF3"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp"
            android:gravity="center" />

        <!-- Device type badge -->
        <TextView
            android:id="@+id/detailMethodBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF00E5FF"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="12dp"
            android:paddingVertical="3dp"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:background="#FF00E5FF"
            android:layout_marginBottom="24dp" />

        <!-- Info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_about"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INFORMACIÓN DEL DISPOSITIVO"
                android:textColor="#FF8B949E"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="16dp" />

            <!-- IP row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="IP"
                    android:textColor="#FF6E7681"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/detailIp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FF00E5FF"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/detailBtnCopyIp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copiar"
                    android:textColor="#FF3FB950"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />
            </LinearLayout>

            <!-- MAC row -->
            <LinearLayout
                android:id="@+id/detailMacRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="MAC"
                    android:textColor="#FF6E7681"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/detailMac"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FFE6EDF3"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/detailBtnCopyMac"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copiar"
                    android:textColor="#FF3FB950"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />
            </LinearLayout>

            <!-- Vendor row -->
            <LinearLayout
                android:id="@+id/detailVendorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Fabricante"
                    android:textColor="#FF6E7681"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/detailVendor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FFE6EDF3"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Method row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Método"
                    android:textColor="#FF6E7681"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/detailMethod"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FF3FB950"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Detail row -->
            <LinearLayout
                android:id="@+id/detailExtraRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detalle"
                    android:textColor="#FF6E7681"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/detailExtra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFE6EDF3"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Ports card -->
        <LinearLayout
            android:id="@+id/detailPortsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_about"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PUERTOS ABIERTOS"
                android:textColor="#FF8B949E"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/detailPortsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_about"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCIONES"
                android:textColor="#FF8B949E"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/detailBtnOpenBrowser"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌐  Abrir en navegador"
                    android:textColor="#FF00E5FF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/drawer_item_bg" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/detailBtnPing"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📶  Ping"
                    android:textColor="#FF3FB950"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/drawer_item_bg" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>

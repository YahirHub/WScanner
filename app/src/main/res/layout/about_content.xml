<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <!-- App icon container -->
    <FrameLayout
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp">

        <View
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/circle_radar_bg" />

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_radar"
            android:alpha="0.7" />
    </FrameLayout>

    <!-- App name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WScanner"
        android:textColor="#FF00E5FF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Network Scanner"
        android:textColor="#FF8B949E"
        android:textSize="13sp"
        android:letterSpacing="0.08"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textColor="#FF6E7681"
        android:textSize="12sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="32dp" />

    <View
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:background="#FF00E5FF"
        android:layout_marginBottom="24dp" />

    <!-- Description card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg_about"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESCRIPCIÓN"
            android:textColor="#FF8B949E"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Escáner de red local gratuito. Descubre todos los dispositivos conectados a tu red WiFi con un motor de escaneo multicapa: ping, mDNS (Bonjour), SSDP (UPnP), NetBIOS, HTTP fingerprinting y más."
            android:textColor="#FFE6EDF3"
            android:textSize="14sp"
            android:lineSpacingExtra="4sp"
            android:fontFamily="sans-serif" />
    </LinearLayout>

    <!-- Features card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg_about"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CARACTERÍSTICAS"
            android:textColor="#FF8B949E"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍  Descubrimiento multicapa"
            android:textColor="#FFE6EDF3"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡  Reporte progresivo en tiempo real"
            android:textColor="#FFE6EDF3"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏷️  Nombres inteligentes de dispositivos"
            android:textColor="#FFE6EDF3"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒  Sin anuncios · Sin rastreo · 100% offline"
            android:textColor="#FFE6EDF3"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Developer card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg_about"
        android:padding="20dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESARROLLADOR"
            android:textColor="#FF8B949E"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thowilabs"
            android:textColor="#FF00E5FF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="thowilabs.com"
            android:textColor="#FF8B949E"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Una alternativa gratuita, sin anuncios ni rastreo."
        android:textColor="#FF6E7681"
        android:textSize="11sp"
        android:gravity="center_horizontal"
        android:layout_marginBottom="32dp" />

</LinearLayout>

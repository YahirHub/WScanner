<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg_primary">

    <!-- Contenido principal -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Toolbar -->
            <com.google.android.material.appbar.AppBarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_secondary"
                app:elevation="0dp">

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    android:background="@color/bg_secondary"
                    app:title="WScanner"
                    app:titleTextColor="#FF00E5FF"
                    app:subtitleTextColor="#FF8B949E"
                    app:elevation="0dp" />

                <!-- Progress bar integrated under toolbar -->
                <ProgressBar
                    android:id="@+id/progressScan"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:visibility="gone"
                    android:progressTint="#FF00E5FF"
                    android:progressBackgroundTint="#FF21262D" />

            </com.google.android.material.appbar.AppBarLayout>

            <!-- ═══ Scanner Content (show/hide with about) ═══ -->
            <LinearLayout
                android:id="@+id/layoutScannerContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

            <!-- Header de información de red -->
            <LinearLayout
                android:id="@+id/layoutNetworkInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/gradient_dark"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtSubnet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FF8B949E"
                        android:textSize="11sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="sans-serif-medium"
                        android:text="SUBRED" />

                    <TextView
                        android:id="@+id/txtSubnetValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FF00E5FF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:text="—"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FF8B949E"
                        android:textSize="11sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="sans-serif-medium"
                        android:text="DISPOSITIVOS" />

                    <TextView
                        android:id="@+id/txtDeviceCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FF3FB950"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:text="0"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FF8B949E"
                        android:textSize="11sp"
                        android:letterSpacing="0.06"
                        android:fontFamily="sans-serif-medium"
                        android:text="GATEWAY" />

                    <TextView
                        android:id="@+id/txtGatewayValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFE6EDF3"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:text="—"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Status text -->
            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Presiona Escanear para buscar dispositivos"
                android:textSize="13sp"
                android:textColor="#FF6E7681"
                android:padding="16dp"
                android:gravity="center" />

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Device list con swipe refresh -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/listDevices"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:clipToPadding="false"
                        android:background="@color/bg_primary" />

                    <!-- Empty state overlay -->
                    <include layout="@layout/empty_state" />

                    <!-- Placeholder cards during scanning -->
                    <include layout="@layout/placeholder_cards" />

                </FrameLayout>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            </LinearLayout><!-- /layoutScannerContent -->

            <!-- ═══ Acerca de content (shown/hidden via nav drawer) ═══ -->
            <ScrollView
                android:id="@+id/layoutAbout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <!-- App icon container -->
                    <FrameLayout
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:background="@drawable/circle_radar_bg" />

                        <ImageView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_radar"
                            android:alpha="0.7" />
                    </FrameLayout>

                    <!-- App name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WScanner"
                        android:textColor="#FF00E5FF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Network Scanner"
                        android:textColor="#FF8B949E"
                        android:textSize="13sp"
                        android:letterSpacing="0.08"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v1.0"
                        android:textColor="#FF6E7681"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="32dp" />

                    <View
                        android:layout_width="48dp"
                        android:layout_height="2dp"
                        android:background="#FF00E5FF"
                        android:layout_marginBottom="24dp" />

                    <!-- Description card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg_about"
                        android:padding="20dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DESCRIPCIÓN"
                            android:textColor="#FF8B949E"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Escáner de red local gratuito. Descubre todos los dispositivos conectados a tu red WiFi con un motor de escaneo multicapa: ping, mDNS (Bonjour), SSDP (UPnP), NetBIOS, HTTP fingerprinting y más."
                            android:textColor="#FFE6EDF3"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4sp"
                            android:fontFamily="sans-serif" />
                    </LinearLayout>

                    <!-- Features card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg_about"
                        android:padding="20dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CARACTERÍSTICAS"
                            android:textColor="#FF8B949E"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔍  Descubrimiento multicapa"
                            android:textColor="#FFE6EDF3"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡  Reporte progresivo en tiempo real"
                            android:textColor="#FFE6EDF3"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏷️  Nombres inteligentes de dispositivos"
                            android:textColor="#FFE6EDF3"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔒  Sin anuncios · Sin rastreo · 100% offline"
                            android:textColor="#FFE6EDF3"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Developer card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg_about"
                        android:padding="20dp"
                        android:layout_marginBottom="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DESARROLLADOR"
                            android:textColor="#FF8B949E"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thowilabs"
                            android:textColor="#FF00E5FF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="thowilabs.com"
                            android:textColor="#FF8B949E"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Una alternativa gratuita, sin anuncios ni rastreo."
                        android:textColor="#FF6E7681"
                        android:textSize="11sp"
                        android:gravity="center_horizontal"
                        android:layout_marginBottom="32dp" />

                </LinearLayout>
            </ScrollView>

        </LinearLayout>

        <!-- FAB de escaneo -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnScan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="24dp"
            android:contentDescription="Escanear red"
            app:backgroundTint="#FF00E5FF"
            app:tint="#FF0D1117"
            app:fabSize="normal"
            app:srcCompat="@drawable/ic_radar"
            app:elevation="8dp" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Drawer lateral -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/bg_secondary"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"
        app:itemTextColor="@color/drawer_text_color"
        app:itemIconTint="@color/drawer_icon_tint"
        app:itemBackground="@drawable/drawer_item_bg"
        app:itemTextAppearance="@style/DrawerText" />

</androidx.drawerlayout.widget.DrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg_primary">

    <!-- Contenido principal -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/rootConstraint"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Toolbar -->
            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/appBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@color/bg_secondary"
                app:elevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    android:background="@color/bg_secondary"
                    app:title="WScanner"
                    app:titleTextColor="#FF00E5FF"
                    app:subtitleTextColor="#FF8B949E"
                    app:elevation="0dp" />

                <!-- Progress bar integrated under toolbar -->
                <ProgressBar
                    android:id="@+id/progressScan"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:visibility="gone"
                    android:progressTint="#FF00E5FF"
                    android:progressBackgroundTint="#FF21262D" />

            </com.google.android.material.appbar.AppBarLayout>

            <!-- ═══ Scanner Content (show/hide with about/detail) ═══ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutScannerContent"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="visible"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/appBar"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Header de información de red -->
                <LinearLayout
                    android:id="@+id/layoutNetworkInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/gradient_dark"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtSubnet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FF8B949E"
                            android:textSize="11sp"
                            android:letterSpacing="0.06"
                            android:fontFamily="sans-serif-medium"
                            android:text="SUBRED" />

                        <TextView
                            android:id="@+id/txtSubnetValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FF00E5FF"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:text="—"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FF8B949E"
                            android:textSize="11sp"
                            android:letterSpacing="0.06"
                            android:fontFamily="sans-serif-medium"
                            android:text="DISPOSITIVOS" />

                        <TextView
                            android:id="@+id/txtDeviceCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FF3FB950"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:text="0"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FF8B949E"
                            android:textSize="11sp"
                            android:letterSpacing="0.06"
                            android:fontFamily="sans-serif-medium"
                            android:text="GATEWAY" />

                        <TextView
                            android:id="@+id/txtGatewayValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFE6EDF3"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:text="—"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Separator 1 -->
                <View
                    android:id="@+id/divider1"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layoutNetworkInfo" />

                <!-- Sort chips row -->
                <LinearLayout
                    android:id="@+id/layoutSortChips"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:gravity="center"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider1">

                    <TextView
                        android:id="@+id/chipSortIp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IP"
                        android:textColor="#FF00E5FF"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/badge_empty_hint"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipSortName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre"
                        android:textColor="#FF8B949E"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipSortVendor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vendor"
                        android:textColor="#FF8B949E"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipSortMethod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Método"
                        android:textColor="#FF8B949E"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Separator 2 -->
                <View
                    android:id="@+id/divider2"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layoutSortChips" />

                <!-- Status text -->
                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Presiona Escanear para buscar dispositivos"
                    android:textSize="13sp"
                    android:textColor="#FF6E7681"
                    android:padding="16dp"
                    android:gravity="center"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider2" />

                <!-- Separator 3 -->
                <View
                    android:id="@+id/divider3"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/txtStatus" />

                <!-- Device list area -->
                <FrameLayout
                    android:id="@+id/listContainer"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider3"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/listDevices"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:clipToPadding="false"
                        android:background="@color/bg_primary" />

                    <!-- Empty state overlay -->
                    <include layout="@layout/empty_state" />

                    <!-- Placeholder cards during scanning -->
                    <include layout="@layout/placeholder_cards" />

                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ═══ Device Detail content (shown on card tap) ═══ -->
            <include
                android:id="@+id/layoutDeviceDetail"
                layout="@layout/layout_device_detail"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/appBar"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- ═══ Acerca de content (shown/hidden via nav drawer) ═══ -->
            <ScrollView
                android:id="@+id/layoutAbout"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:padding="24dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/appBar"
                app:layout_constraintBottom_toBottomOf="parent">

                <include layout="@layout/about_content" />
            </ScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- FAB de escaneo -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnScan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="24dp"
            android:contentDescription="Escanear red"
            app:backgroundTint="#FF00E5FF"
            app:tint="#FF0D1117"
            app:fabSize="normal"
            app:srcCompat="@drawable/ic_radar"
            app:elevation="8dp" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Drawer lateral -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/bg_secondary"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"
        app:itemTextColor="@color/drawer_text_color"
        app:itemIconTint="@color/drawer_icon_tint"
        app:itemBackground="@drawable/drawer_item_bg"
        app:itemTextAppearance="@style/DrawerText" />

</androidx.drawerlayout.widget.DrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/rootConstraint"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/appBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@color/bg_secondary"
                app:elevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.appbar.MaterialToolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:background="@color/bg_secondary"
                    android:paddingEnd="4dp"
                    app:elevation="0dp"
                    app:subtitle="Analizador de red local"
                    app:subtitleTextColor="@color/text_tertiary"
                    app:title="WScanner"
                    app:titleTextColor="@color/text_primary" />

                <ProgressBar
                    android:id="@+id/progressScan"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:indeterminateTint="@color/accent_primary"
                    android:progressBackgroundTint="@color/bg_surface"
                    android:progressTint="@color/accent_primary"
                    android:visibility="gone" />
            </com.google.android.material.appbar.AppBarLayout>

            <androidx.coordinatorlayout.widget.CoordinatorLayout
                android:id="@+id/layoutScannerContent"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/bg_screen_glow"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/appBar">

                <!-- El resumen y el estado forman parte del mismo desplazamiento que la lista. -->
                <com.google.android.material.appbar.AppBarLayout
                    android:id="@+id/scannerHeaderAppBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    app:elevation="0dp"
                    app:liftOnScroll="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_scrollFlags="scroll|enterAlways">

                        <include
                            layout="@layout/network_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                        <include
                            android:id="@+id/scanStatusInclude"
                            layout="@layout/scanner_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </com.google.android.material.appbar.AppBarLayout>

                <FrameLayout
                    android:id="@+id/listContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:layout_behavior="@string/appbar_scrolling_view_behavior">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/listDevices"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="true"
                        android:overScrollMode="never"
                        android:paddingStart="16dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="104dp"
                        android:scrollbars="none" />

                    <include layout="@layout/empty_state" />
                    <include layout="@layout/placeholder_cards" />
                </FrameLayout>
            </androidx.coordinatorlayout.widget.CoordinatorLayout>

            <include
                android:id="@+id/layoutDeviceDetail"
                layout="@layout/layout_device_detail"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/appBar" />

            <ScrollView
                android:id="@+id/layoutAbout"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/bg_screen_glow"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:paddingStart="20dp"
                android:paddingTop="12dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/appBar"
                android:scrollbars="none">

                <include layout="@layout/about_content" />
            </ScrollView>

            <include
                android:id="@+id/layoutSpeedTest"
                layout="@layout/tool_speedtest"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/appBar" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnScan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="22dp"
            android:contentDescription="Escanear red"
            app:backgroundTint="@color/accent_primary"
            app:borderWidth="0dp"
            app:elevation="10dp"
            app:fabSize="normal"
            app:hoveredFocusedTranslationZ="4dp"
            app:maxImageSize="25dp"
            app:pressedTranslationZ="8dp"
            app:rippleColor="@color/accent_light"
            app:srcCompat="@drawable/ic_radar"
            app:tint="@color/bg_primary" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="304dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/bg_secondary"
        android:fitsSystemWindows="false"
        app:headerLayout="@layout/nav_header"
        app:itemBackground="@drawable/drawer_item_bg"
        app:itemHorizontalPadding="18dp"
        app:itemIconPadding="16dp"
        app:itemIconTint="@color/drawer_icon_tint"
        app:itemTextAppearance="@style/DrawerText"
        app:itemTextColor="@color/drawer_text_color"
        app:itemVerticalPadding="8dp"
        app:menu="@menu/drawer_menu" />
</androidx.drawerlayout.widget.DrawerLayout>
